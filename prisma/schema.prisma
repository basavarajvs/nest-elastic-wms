generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["multitenant"]
}

// ── Enums ──
enum FacilityType {
  WAREHOUSE           @map("WAREHOUSE")
  DISTRIBUTION_CENTER @map("DISTRIBUTION_CENTER")
  CROSS_DOCK          @map("CROSS_DOCK")
  FULFILLMENT_CENTER  @map("FULFILLMENT_CENTER")

  @@schema("multitenant")
}

enum ZoneType {
  BULK     @map("BULK")
  PICKING  @map("PICKING")
  RECEIVING @map("RECEIVING")
  SHIPPING @map("SHIPPING")
  PACKING  @map("PACKING")
  STAGING  @map("STAGING")
  QC       @map("QC")
  HOLD     @map("HOLD")
  YARD     @map("YARD")

  @@schema("multitenant")
}

enum LocationType {
  PALLET @map("PALLET")
  CASE   @map("CASE")
  EACH   @map("EACH")
  FLOOR  @map("FLOOR")
  STAGING @map("STAGING")
  DOCK   @map("DOCK")
  TEMP   @map("TEMP")

  @@schema("multitenant")
}

// ── Quota Model ──
model ResourceQuota {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  resourceType String   @map("resource_type") @db.VarChar(100)
  limitAmount  Int      @map("limit_amount")
  currentUsage Int      @default(0) @map("current_usage")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, resourceType], name: "resource_quotas_type_uq")
  @@schema("multitenant")
  @@map("resource_quotas")
}

// ── Warehouse Hierarchy (Lean 3-table) ──
model WarehouseFacility {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  facilityCode String         @map("facility_code") @db.VarChar(50)
  name         String         @db.VarChar(255)
  facilityType FacilityType   @default(WAREHOUSE) @map("facility_type")
  isActive     Boolean        @default(true) @map("is_active")
  attributes   Json?          @db.Json
  zones        WarehouseZone[]
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityCode], name: "warehouse_facilities_code_uq")
  @@schema("multitenant")
  @@map("warehouse_facilities")
}

model WarehouseZone {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  facilityId String           @map("facility_id") @db.Uuid
  zoneCode   String           @map("zone_code") @db.VarChar(50)
  name       String           @db.VarChar(255)
  zoneType   ZoneType         @map("zone_type")
  isActive   Boolean          @default(true) @map("is_active")
  attributes Json?            @db.Json
  locations  StorageLocation[]
  facility   WarehouseFacility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, zoneCode], name: "warehouse_zones_code_uq")
  @@schema("multitenant")
  @@map("warehouse_zones")
}

model StorageLocation {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  facilityId   String           @map("facility_id") @db.Uuid
  zoneId       String           @map("zone_id") @db.Uuid
  parentId     String?          @map("parent_id") @db.Uuid
  locationCode String           @map("location_code") @db.VarChar(100)
  locationType LocationType     @map("location_type")
  isActive     Boolean          @default(true) @map("is_active")
  isBlocked    Boolean          @default(false) @map("is_blocked")
  attributes   Json?            @db.Json
  children     StorageLocation[] @relation("LocationHierarchy")
  parent       StorageLocation?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  zone         WarehouseZone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, locationCode], name: "storage_locations_code_uq")
  @@index([tenantId, facilityId, zoneId], name: "idx_sl_tenant_facility_zone")
  @@schema("multitenant")
  @@map("storage_locations")
}

// ── Product Catalog Enums ──
enum CategoryStatus {
  ACTIVE   @map("ACTIVE")
  INACTIVE @map("INACTIVE")

  @@schema("multitenant")
}

enum BarcodeType {
  CODE128  @map("CODE128")
  EAN13    @map("EAN13")
  UPC_A    @map("UPC_A")
  GS1_128  @map("GS1_128")
  QR_CODE  @map("QR_CODE")
  INTERNAL @map("INTERNAL")

  @@schema("multitenant")
}

// ── Product Catalog ──
model ProductCategory {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  parentId     String?           @map("parent_id") @db.Uuid
  categoryCode String            @map("category_code") @db.VarChar(50)
  name         String            @db.VarChar(255)
  status       CategoryStatus    @default(ACTIVE) @map("status")
  children     ProductCategory[] @relation("CategoryTree")
  parent       ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  products     Product[]
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, categoryCode], name: "product_categories_code_uq")
  @@index([tenantId, status], name: "idx_pc_tenant_status")
  @@schema("multitenant")
  @@map("product_categories")
}

model UnitOfMeasure {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  code      String    @map("code") @db.VarChar(10)
  name      String    @db.VarChar(100)
  isBase    Boolean   @default(false) @map("is_base")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, code], name: "units_of_measure_code_uq")
  @@schema("multitenant")
  @@map("units_of_measure")
}

model Product {
  id            String             @id @default(uuid()) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  categoryId    String             @map("category_id") @db.Uuid
  baseUomId     String             @map("base_uom_id") @db.Uuid
  productCode   String             @map("product_code") @db.VarChar(100)
  name          String             @db.VarChar(255)
  description   String?            @db.Text
  isActive      Boolean            @default(true) @map("is_active")
  trackLot      Boolean            @default(false) @map("track_lot")
  trackSerial   Boolean            @default(false) @map("track_serial")
  trackExpiry   Boolean            @default(false) @map("track_expiry")
  shelfLifeDays Int?               @map("shelf_life_days")
  velocityClass String?            @map("velocity_class") @db.VarChar(1)
  attributes    ProductAttribute[]
  barcodes      ProductBarcode[]
  category      ProductCategory    @relation(fields: [categoryId], references: [id])
  baseUom       UnitOfMeasure      @relation(fields: [baseUomId], references: [id])
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, productCode], name: "products_code_uq")
  @@index([tenantId, isActive], name: "idx_prod_tenant_active")
  @@index([tenantId, velocityClass], name: "idx_prod_velocity")
  @@schema("multitenant")
  @@map("products")
}

model ProductBarcode {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  productId    String    @map("product_id") @db.Uuid
  barcodeValue String    @unique @map("barcode_value") @db.VarChar(200)
  type         BarcodeType @default(CODE128) @map("type")
  isPrimary    Boolean   @default(false) @map("is_primary")
  isActive     Boolean   @default(true) @map("is_active")
  quantityPerScan Int?   @default(1) @map("quantity_per_scan")
  childUomCode String?   @map("child_uom_code") @db.VarChar(10)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([barcodeValue, tenantId], name: "idx_pb_barcode_tenant")
  @@index([tenantId, isActive], name: "idx_pb_tenant_active")
  @@schema("multitenant")
  @@map("product_barcodes")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  key       String   @map("key") @db.VarChar(100)
  value     String   @map("value") @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, productId, key], name: "product_attributes_uq")
  @@schema("multitenant")
  @@map("product_attributes")
}

model ProductImportJob {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  fileName      String               @map("file_name") @db.VarChar(255)
  status        String               @default("PENDING") @map("status") @db.VarChar(20)
  totalRows     Int                  @default(0) @map("total_rows")
  processedRows Int                  @default(0) @map("processed_rows")
  successRows   Int                  @default(0) @map("success_rows")
  failedRows    Int                  @default(0) @map("failed_rows")
  errorSummary  String?              @map("error_summary") @db.Text
  completedAt   DateTime?            @map("completed_at") @db.Timestamptz
  results       ProductImportResult[]
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, status], name: "idx_pij_tenant_status")
  @@schema("multitenant")
  @@map("product_import_jobs")
}

model ProductImportResult {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  jobId        String            @map("job_id") @db.Uuid
  rowNum       Int               @map("row_num")
  productCode  String?           @map("product_code") @db.VarChar(100)
  status       String            @map("status") @db.VarChar(20)
  errorMessage String?           @map("error_message") @db.Text
  job          ProductImportJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, jobId, status], name: "idx_pir_job_status")
  @@schema("multitenant")
  @@map("product_import_results")
}

// ── Inventory Enums ──
enum TransactionType {
  RECEIPT              @map("RECEIPT")
  PUTAWAY              @map("PUTAWAY")
  PICK                 @map("PICK")
  PACK                 @map("PACK")
  SHIP                 @map("SHIP")
  ADJUSTMENT_INCREASE  @map("ADJUSTMENT_INCREASE")
  ADJUSTMENT_DECREASE  @map("ADJUSTMENT_DECREASE")
  TRANSFER_IN          @map("TRANSFER_IN")
  TRANSFER_OUT         @map("TRANSFER_OUT")
  CYCLE_COUNT_RESERVE  @map("CYCLE_COUNT_RESERVE")
  CYCLE_COUNT_RELEASE  @map("CYCLE_COUNT_RELEASE")
  HOLD_RELEASE         @map("HOLD_RELEASE")
  QC_PASS              @map("QC_PASS")
  QC_FAIL              @map("QC_FAIL")
  REWORK               @map("REWORK")
  SCRAPP               @map("SCRAPP")

  @@schema("multitenant")
}

enum TransactionStatus {
  COMPLETED @map("COMPLETED")
  CANCELLED @map("CANCELLED")
  ERROR     @map("ERROR")

  @@schema("multitenant")
}

enum HoldType {
  QC_PENDING       @map("QC_PENDING")
  QC_FAILED        @map("QC_FAILED")
  DAMAGE           @map("DAMAGE")
  CYCLE_COUNT      @map("CYCLE_COUNT")
  CREDIT_HOLD      @map("CREDIT_HOLD")
  CUSTOMER_REQUEST @map("CUSTOMER_REQUEST")
  QUARANTINE       @map("QUARANTINE")

  @@schema("multitenant")
}

enum HoldStatus {
  ACTIVE   @map("ACTIVE")
  RELEASED @map("RELEASED")
  EXPIRED  @map("EXPIRED")

  @@schema("multitenant")
}

// ── Inventory & Stock Management ──
model InventoryLot {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  facilityId        String           @map("facility_id") @db.Uuid
  productId         String           @map("product_id") @db.Uuid
  lotNumber         String           @map("lot_number") @db.VarChar(100)
  supplierLotNumber String?          @map("supplier_lot_number") @db.VarChar(100)
  mfgDate           DateTime?        @map("mfg_date") @db.Date
  expiryDate        DateTime?        @map("expiry_date") @db.Date
  receivedDate      DateTime         @default(now()) @map("received_date") @db.Timestamptz
  status            String           @default("AVAILABLE") @map("status") @db.VarChar(20)
  onHands           InventoryOnHand[]
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, productId, lotNumber], name: "inventory_lots_uq")
  @@index([tenantId, productId, expiryDate], name: "idx_lot_fefo")
  @@schema("multitenant")
  @@map("inventory_lots")
}

model InventoryOnHand {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  facilityId        String        @map("facility_id") @db.Uuid
  productId         String        @map("product_id") @db.Uuid
  locationId        String        @map("location_id") @db.Uuid
  lotId             String        @map("lot_id") @db.Uuid
  quantityOnHand    Float         @default(0) @map("quantity_on_hand")
  quantityAllocated Float         @default(0) @map("quantity_allocated")
  quantityReserved  Float         @default(0) @map("quantity_reserved")
  quantityPicked    Float         @default(0) @map("quantity_picked")
  quantityOnHold    Float         @default(0) @map("quantity_on_hold")
  quantityDamaged   Float         @default(0) @map("quantity_damaged")
  uomId             String        @map("uom_id") @db.Uuid
  lot               InventoryLot  @relation(fields: [lotId], references: [id])
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, productId, locationId, lotId], name: "inventory_on_hand_uq")
  @@index([tenantId, facilityId, productId], name: "idx_onhand_product")
  @@index([tenantId, facilityId, locationId], name: "idx_onhand_location")
  @@schema("multitenant")
  @@map("inventory_on_hand")
}

model InventoryTransaction {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  productId         String            @map("product_id") @db.Uuid
  locationId        String?           @map("location_id") @db.Uuid
  locationIdTo      String?           @map("location_id_to") @db.Uuid
  lotId             String?           @map("lot_id") @db.Uuid
  transactionType   TransactionType   @map("transaction_type")
  transactionStatus TransactionStatus @default(COMPLETED) @map("transaction_status")
  quantity          Float             @map("quantity")
  quantityBefore    Float             @map("quantity_before")
  quantityAfter     Float             @map("quantity_after")
  uomId             String            @map("uom_id") @db.Uuid
  referenceType     String            @map("reference_type") @db.VarChar(50)
  referenceId       String?           @map("reference_id") @db.VarChar(100)
  reasonCode        String?           @map("reason_code") @db.VarChar(50)
  performedByUserId String?           @map("performed_by_user_id") @db.Uuid
  metadata          Json?             @db.Json
  transactionAt     DateTime          @default(now()) @map("transaction_at") @db.Timestamptz
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, productId, transactionAt(sort: Desc)], name: "idx_txn_product_time")
  @@index([tenantId, locationId], name: "idx_txn_location")
  @@index([tenantId, referenceType, referenceId], name: "idx_txn_reference")
  @@schema("multitenant")
  @@map("inventory_transactions")
}

model InventoryHold {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  facilityId       String     @map("facility_id") @db.Uuid
  productId        String?    @map("product_id") @db.Uuid
  locationId       String?    @map("location_id") @db.Uuid
  lotId            String?    @map("lot_id") @db.Uuid
  holdType         HoldType   @map("hold_type")
  status           HoldStatus @default(ACTIVE) @map("status")
  reason           String?    @map("reason") @db.Text
  placedByUserId   String     @map("placed_by_user_id") @db.Uuid
  releasedByUserId String?    @map("released_by_user_id") @db.Uuid
  releasedAt       DateTime?  @map("released_at") @db.Timestamptz
  expiresAt        DateTime?  @map("expires_at") @db.Timestamptz
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, status], name: "idx_hold_status")
  @@index([tenantId, lotId, status], name: "idx_hold_lot_status")
  @@schema("multitenant")
  @@map("inventory_holds")
}

model InventoryAdjustment {
  id                  String                    @id @default(uuid()) @db.Uuid
  tenantId            String                    @map("tenant_id") @db.Uuid
  facilityId          String                    @map("facility_id") @db.Uuid
  adjustmentNumber    String                    @map("adjustment_number") @db.VarChar(50)
  status              String                    @default("DRAFT") @map("status") @db.VarChar(20)
  reasonCode          String                    @map("reason_code") @db.VarChar(50)
  requestedByUserId   String                    @map("requested_by_user_id") @db.Uuid
  approvedByUserId    String?                   @map("approved_by_user_id") @db.Uuid
  notes               String?                   @map("notes") @db.Text
  lines               InventoryAdjustmentLine[]
  createdAt           DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, adjustmentNumber], name: "inventory_adjustments_uq")
  @@schema("multitenant")
  @@map("inventory_adjustments")
}

model InventoryAdjustmentLine {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  facilityId         String              @map("facility_id") @db.Uuid
  adjustmentId       String              @map("adjustment_id") @db.Uuid
  productId          String              @map("product_id") @db.Uuid
  locationId         String              @map("location_id") @db.Uuid
  lotId              String?             @map("lot_id") @db.Uuid
  quantityBefore     Float               @map("quantity_before")
  quantityAdjustment Float               @map("quantity_adjustment")
  quantityAfter      Float               @map("quantity_after")
  uomId              String              @map("uom_id") @db.Uuid
  adjustment         InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, adjustmentId], name: "idx_adj_line_adjustment")
  @@schema("multitenant")
  @@map("inventory_adjustment_lines")
}

model InventoryPolicy {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  facilityId    String   @map("facility_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  locationId    String?  @map("location_id") @db.Uuid
  reorderPoint  Float    @map("reorder_point")
  maxStockLevel Float    @map("max_stock_level")
  safetyStock   Float    @default(0) @map("safety_stock")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, productId, locationId], name: "inventory_policies_uq")
  @@schema("multitenant")
  @@map("inventory_policies")
}

// ── Inbound/Receiving Enums ──
enum AsnStatus {
  CREATED               @map("CREATED")
  IN_TRANSIT            @map("IN_TRANSIT")
  ARRIVED               @map("ARRIVED")
  IN_RECEIVING          @map("IN_RECEIVING")
  PARTIALLY_RECEIVED    @map("PARTIALLY_RECEIVED")
  RECEIVED              @map("RECEIVED")
  CLOSED                @map("CLOSED")
  CANCELLED             @map("CANCELLED")

  @@schema("multitenant")
}

enum GrnStatus {
  CREATED               @map("CREATED")
  ARRIVED               @map("ARRIVED")
  RECEIVING             @map("RECEIVING")
  PARTIAL               @map("PARTIAL")
  RECEIVED              @map("RECEIVED")
  INSPECTION_IN_PROGRESS @map("INSPECTION_IN_PROGRESS")
  INSPECTED             @map("INSPECTED")
  COMPLETED             @map("COMPLETED")
  CANCELLED             @map("CANCELLED")

  @@schema("multitenant")
}

enum GrnLineStatus {
  OPEN                  @map("OPEN")
  RECEIVING             @map("RECEIVING")
  RECEIVED              @map("RECEIVED")
  QC_PENDING            @map("QC_PENDING")
  QC_PASSED             @map("QC_PASSED")
  QC_FAILED             @map("QC_FAILED")
  PUTAWAY_PENDING       @map("PUTAWAY_PENDING")
  PUTAWAY_DONE          @map("PUTAWAY_DONE")
  CANCELLED             @map("CANCELLED")

  @@schema("multitenant")
}

enum LpnStatus {
  RECEIVED              @map("RECEIVED")
  IN_STAGING            @map("IN_STAGING")
  IN_QC                 @map("IN_QC")
  PUTAWAY_PENDING       @map("PUTAWAY_PENDING")
  STORED                @map("STORED")
  QUARANTINED           @map("QUARANTINED")
  CONSUMED              @map("CONSUMED")
  DISPOSED              @map("DISPOSED")
  NESTED                @map("NESTED")

  @@schema("multitenant")
}

enum LpnType {
  PALLET                @map("PALLET")
  CARTON                @map("CARTON")
  CASE                  @map("CASE")
  EACH                  @map("EACH")
  MIXED                 @map("MIXED")

  @@schema("multitenant")
}

enum DispositionAction {
  ACCEPT                @map("ACCEPT")
  REJECT                @map("REJECT")
  QUARANTINE            @map("QUARANTINE")
  RETURN_TO_VENDOR      @map("RETURN_TO_VENDOR")
  REWORK                @map("REWORK")
  DESTROY               @map("DESTROY")

  @@schema("multitenant")
}

// ── Inbound / Receiving ──
