  PARTIALLY_RECEIVED @map("PARTIALLY_RECEIVED")
  RECEIVED  @map("RECEIVED")
  CANCELLED @map("CANCELLED")

  @@schema("multitenant")
}

enum CountMethod {
  BLIND         @map("BLIND")
  KNOWN         @map("KNOWN")
  SPOT          @map("SPOT")
  CONTROL_GROUP @map("CONTROL_GROUP")

  @@schema("multitenant")
}

enum CountStatus {
  SCHEDULED  @map("SCHEDULED")
  ASSIGNED   @map("ASSIGNED")
  IN_PROGRESS @map("IN_PROGRESS")
  COMPLETED  @map("COMPLETED")
  RECONCILED @map("RECONCILED")
  CANCELLED  @map("CANCELLED")

  @@schema("multitenant")
}

enum CountFrequencyType {
  MANUAL       @map("MANUAL")
  DAILY        @map("DAILY")
  WEEKLY       @map("WEEKLY")
  MONTHLY      @map("MONTHLY")
  QUARTERLY    @map("QUARTERLY")
  ABC_DRIVEN   @map("ABC_DRIVEN")

  @@schema("multitenant")
}

enum ApprovalLevel {
  AUTO_APPROVED @map("AUTO_APPROVED")
  SUPERVISOR    @map("SUPERVISOR")
  MANAGER       @map("MANAGER")
  DIRECTOR      @map("DIRECTOR")

  @@schema("multitenant")
}

enum ApprovalStatus {
  PENDING    @map("PENDING")
  APPROVED   @map("APPROVED")
  REJECTED   @map("REJECTED")
  ESCALATED  @map("ESCALATED")

  @@schema("multitenant")
}

// ── Transfers ──
model InventoryTransfer {
  id                  String                @id @default(uuid()) @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  facilityId          String                @map("facility_id") @db.Uuid
  transferNumber      String                @map("transfer_number") @db.VarChar(50)
  transferType        TransferType          @default(INTRA_FACILITY) @map("transfer_type")
  status              TransferStatus        @default(DRAFT) @map("status")
  fromLocationId      String?               @map("from_location_id") @db.Uuid
  toLocationId        String                @map("to_location_id") @db.Uuid
  toFacilityId        String?               @map("to_facility_id") @db.Uuid
  requestedByUserId   String?               @map("requested_by_user_id") @db.Uuid
  dispatchedByUserId  String?               @map("dispatched_by_user_id") @db.Uuid
  receivedByUserId    String?               @map("received_by_user_id") @db.Uuid
  notes               String?               @map("notes") @db.Text
  lines               InventoryTransferLine[]
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, transferNumber], name: "inventory_transfers_uq")
  @@index([tenantId, facilityId, status], name: "idx_trf_status")
  @@schema("multitenant")
  @@map("inventory_transfers")
}

model InventoryTransferLine {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  facilityId        String             @map("facility_id") @db.Uuid
  transferId        String             @map("transfer_id") @db.Uuid
  productId         String             @map("product_id") @db.Uuid
  lotId             String?            @map("lot_id") @db.Uuid
  uomId             String             @map("uom_id") @db.Uuid
  quantityRequested Float              @map("quantity_requested")
  quantityShipped   Float              @default(0) @map("quantity_shipped")
  quantityReceived  Float              @default(0) @map("quantity_received")
  status            String             @default("REQUESTED") @map("status") @db.VarChar(20)
  transfer          InventoryTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, transferId], name: "idx_trfl_transfer")
  @@schema("multitenant")
  @@map("inventory_transfer_lines")
}

// ── Cycle Counts ──
model CycleCount {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  facilityId        String             @map("facility_id") @db.Uuid
  countNumber       String             @map("count_number") @db.VarChar(50)
  countMethod       CountMethod        @default(BLIND) @map("count_method")
  status            CountStatus        @default(SCHEDULED) @map("status")
  scopeType         String             @map("scope_type") @db.VarChar(20)
  scopeIdentifier   String?            @map("scope_identifier") @db.VarChar(50)
  frequencyType     CountFrequencyType @default(MANUAL) @map("frequency_type")
  assignedToUserId  String?            @map("assigned_to_user_id") @db.Uuid
  scheduledDate     DateTime?          @map("scheduled_date") @db.Timestamptz
  startedAt         DateTime?          @map("started_at") @db.Timestamptz
  completedAt       DateTime?          @map("completed_at") @db.Timestamptz
  autoAdjust        Boolean            @default(false) @map("auto_adjust")
  notes             String?            @map("notes") @db.Text
  lines             CycleCountLine[]
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, countNumber], name: "cycle_counts_uq")
  @@index([tenantId, facilityId, status], name: "idx_cc_status")
  @@index([tenantId, facilityId, frequencyType, status], name: "idx_cc_freq")
  @@schema("multitenant")
  @@map("cycle_counts")
}

model CycleCountLine {
  id                String      @id @default(uuid()) @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  facilityId        String      @map("facility_id") @db.Uuid
  countId           String      @map("count_id") @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  locationId        String      @map("location_id") @db.Uuid
  lotId             String?     @map("lot_id") @db.Uuid
  uomId             String      @map("uom_id") @db.Uuid
  systemQuantity    Float       @default(0) @map("system_quantity")
  countedQuantity   Float?      @map("counted_quantity")
  varianceQuantity  Float?      @map("variance_quantity")
  status            String      @default("PENDING") @map("status") @db.VarChar(20)
  countedByUserId   String?     @map("counted_by_user_id") @db.Uuid
  countedAt         DateTime?   @map("counted_at") @db.Timestamptz
  count             CycleCount  @relation(fields: [countId], references: [id])
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, countId], name: "idx_ccl_count")
  @@index([tenantId, facilityId, productId, status], name: "idx_ccl_product_status")
  @@schema("multitenant")
  @@map("cycle_count_lines")
}

// ── Adjustment Approvals ──
model AdjustmentApproval {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  facilityId        String           @map("facility_id") @db.Uuid
  countLineId       String?          @map("count_line_id") @db.Uuid
  transferLineId    String?          @map("transfer_line_id") @db.Uuid
  varianceValue     Float            @map("variance_value")
  varianceQty       Float            @map("variance_qty")
  approvalLevel     ApprovalLevel    @default(AUTO_APPROVED) @map("approval_level")
  status            ApprovalStatus   @default(PENDING) @map("status")
  thresholdVersion  String?          @map("threshold_version") @db.VarChar(20)
  requestedByUserId String           @map("requested_by_user_id") @db.Uuid
  assignedToUserId  String?          @map("assigned_to_user_id") @db.Uuid
  approvedByUserId  String?          @map("approved_by_user_id") @db.Uuid
  comments          String?          @map("comments") @db.Text
  rejectionReason   String?          @map("rejection_reason") @db.Text
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, facilityId, status, approvalLevel], name: "idx_aa_status_level")
  @@schema("multitenant")
  @@map("adjustment_approvals")
}

// ── Threshold Versioning History ──
model ApprovalThresholdConfig {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  version           String   @map("version") @db.VarChar(20)
  autoThreshold     Float    @map("auto_threshold")
  supervisorThreshold Float  @map("supervisor_threshold")
  managerThreshold   Float   @map("manager_threshold")
  active            Boolean  @default(true) @map("active")
  appliedAt         DateTime @default(now()) @map("applied_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, version], name: "threshold_config_uq")
  @@index([tenantId, active], name: "idx_threshold_active")
  @@schema("multitenant")
  @@map("approval_threshold_configs")
}

// ── Count Scheduler Metrics ──
model CountSchedulerMetric {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  runAt               DateTime @default(now()) @map("run_at") @db.Timestamptz
  generationDurationMs Int     @map("generation_duration_ms")
  successRate         Float    @map("success_rate")
  totalGenerated      Int      @map("total_generated")
  failedProductCodes  Json?    @map("failed_product_codes") @db.Json
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, runAt], name: "idx_csm_run")
  @@schema("multitenant")
  @@map("count_scheduler_metrics")
}

// ── System Settings History (migration-safe audit) ──
model SystemSettingHistory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  settingKey  String   @map("setting_key") @db.VarChar(100)
  oldValue    Json?    @map("old_value") @db.Json
  newValue    Json?    @map("new_value") @db.Json
  changedBy   String?  @map("changed_by") @db.VarChar(100)
  changedAt   DateTime @default(now()) @map("changed_at") @db.Timestamptz

  @@index([tenantId, settingKey, changedAt], name: "idx_ssh_key_time")
  @@schema("multitenant")
  @@map("system_setting_histories")
}
