  @@schema("multitenant")
  @@map("carrier_rates")
}

// ── P2: Warehouse Hierarchy — Aisle ──
model Aisle {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  facilityId String  @map("facility_id") @db.Uuid
  zoneId    String   @map("zone_id") @db.Uuid
  aisleCode String   @map("aisle_code") @db.VarChar(20)
  name      String?  @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  bays      Bay[]
  zone      WarehouseZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, facilityId, zoneId, aisleCode], name: "aisles_uq")
  @@index([tenantId, facilityId, zoneId], name: "idx_aisles_zone")
  @@schema("multitenant")
  @@map("warehouse_aisles")
}

