{
  "name": "wms-app",
  "version": "1.0.0-wms",
  "description": "WMS Application - Domain-specific warehouse management on SaaS Core",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "postbuild": "mkdir -p dist/generated && cp -r generated/prisma dist/generated/prisma/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run build && node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "pnpx prisma migrate deploy",
    "db:studio": "pnpx prisma studio",
    "db:reset": "pnpx prisma migrate reset --force",
    "migrate:legacy": "ts-node scripts/migrate-legacy.ts",
    "warmup:cache": "ts-node scripts/warm-cache.ts",
    "load:test": "k6 run load-tests/rf-barcode-spike.js --out json=load-results.json",
    "load:test:inventory": "k6 run load-tests/inventory-transactions.js --out json=load-results.json",
    "load:test:queue": "k6 run load-tests/async-queue-pressure.js --out json=load-results.json",
    "cutover:check": "bash scripts/rollout-check.sh",
    "cutover:verify": "bash scripts/migrations/verify_rls.sql | psql '$DATABASE_URL'",
    "replay:dlq": "node -e \"const { Queue } = require('bullmq'); const q = new Queue('wms-notifications-dlq', { connection: { host: process.env.REDIS_HOST } }); q.retryJobs({ count: 100 }).then(() => process.exit(0));\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@casl/ability": "^6.8.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@gorules/zen-engine": "^0.54.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/instrumentation-redis-4": "^0.49.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@prisma/client": "^5.22.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.9.0",
    "bpmn-engine": "^25.0.1",
    "bpmn-moddle": "^10.0.0",
    "bullmq": "^5.76.8",
    "camunda-bpmn-moddle": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-stringify": "^6.7.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "xstate": "^5.31.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "jest": "^30.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
    ]
  }
}
