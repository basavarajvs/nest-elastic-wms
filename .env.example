NODE_ENV=development
PORT=3001
API_PREFIX=api/v1/wms
APP_URL=http://localhost:3001
LOG_LEVEL=info

DATABASE_URL=postgresql://elasticwmsdbadmin:elasticwmsdbadmin@localhost:5432/elasticwms?schema=multitenant

CORE_API_URL=http://localhost:3000/api/v1
CORE_API_TOKEN=changeme-minimum-32-chars-long-token-here

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_PATH=/metrics
SHUTDOWN_TIMEOUT_MS=15000
DB_POOL_LIMIT=20
HEAP_WARNING_THRESHOLD_MB=1200

# Cluster / Deployment
DEPLOYMENT_MODE=rolling
MIGRATION_LOCK_TIMEOUT_MS=300000
JWT_ACCESS_SECRET_OLD=
PGBOUNCER_ENABLED=false

# API Documentation
SWAGGER_ENABLED=true

# Security
CORS_ORIGINS=http://localhost:3000,http://admin.wms.example.com
RATE_LIMIT_GLOBAL_TTL=60000
RATE_LIMIT_GLOBAL_LIMIT=100

# Prompt 25 — Production Validation Tooling
# E2E_TEST_DB_URL=postgresql://elasticwmsdbadmin:elasticwmsdbadmin@localhost:5432/elasticwms?schema=e2e_test
LOAD_TEST_DURATION=5m
MIGRATION_BATCH_SIZE=100
CUTOVER_TIMEOUT_MS=300000
SMOKE_TEST_RH_TOKEN=
IDEMPOTENCY_TTL_MS=300000
WARMUP_BARCODE_COUNT=1000
WARMUP_CONCURRENCY=50
WARMUP_CACHE_TTL_S=900
STEADY_CACHE_TTL_S=7200
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
